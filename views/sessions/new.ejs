<% layout('layouts/boilerplate') %>

<div class="container py-5">
    <div class="row justify-content-center mt-lg-5">
        <div class="col-md-6 col-lg-5">
            
            <header class="mb-5">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <small class="ren-mono text-uppercase opacity-40" style="letter-spacing: 2px;">
                        > NEW_DATA_ENTRY
                    </small>
                    <span class="badge rounded-0 border border-dark border-opacity-10 text-dark fw-800 px-3 py-2 ren-mono small bg-light">
                        <%= slot.toUpperCase() %>_SLOT
                    </span>
                </div>
                
                <h2 class="fw-800 mb-0 ren-mono text-uppercase display-6" style="letter-spacing: -1px;">
                    <%= goal.title %>
                </h2>
            </header>

            <div class="p-4 p-md-5 border border-dark border-opacity-10 bg-white shadow-sm">
                <form action="/sessions" method="POST" id="log-form" novalidate class="validated-form">
                    <input type="hidden" name="session[goalId]" value="<%= goal._id %>">
                    <input type="hidden" name="session[slot]" value="<%= slot %>">

                    <div class="mb-4">
                        <label class="ren-mono small opacity-50 text-uppercase d-block mb-2">Achievement_Label</label>
                        <input type="text" 
                               name="session[title]" 
                               class="form-control bg-light border-0 rounded-0 p-3 ren-mono fw-bold shadow-none" 
                               placeholder="What was accomplished?" 
                               autofocus required>
                    </div>

                    <div class="mb-4">
                        <label class="ren-mono small opacity-50 text-uppercase d-block mb-2">Duration_Invested (MINS)</label>
                        <input type="number" 
                               name="session[duration]" 
                               class="form-control bg-light border-0 rounded-0 p-3 ren-mono fw-bold shadow-none" 
                               placeholder="e.g. 45" 
                               required>
                    </div>

                    <div class="mb-5">
                        <label class="ren-mono small opacity-50 text-uppercase d-block mb-2">Session_Notes (Optional)</label>
                        <textarea name="session[description]" 
                                  class="form-control bg-light border-0 rounded-0 p-3 ren-mono" 
                                  placeholder="Document details or thought process..."
                                  rows="3"></textarea>
                    </div>

                    <div class="d-grid gap-3">
                        <button type="submit" class="btn btn-dark py-3 ren-mono fw-bold text-uppercase rounded-0">
                            COMMIT_ENTRY [+<%= 10 %> UNITS]
                        </button>
                        <a href="/dashboard" class="btn btn-link text-muted text-decoration-none small ren-mono text-uppercase opacity-50 hover-opacity-100 p-0 text-center">
                            [ ABORT_ENTRY ]
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<div id="loading-overlay" class="d-none position-fixed top-0 start-0 w-100 h-100 d-flex justify-content-center align-items-center" style="background: rgba(255,255,255,0.98); z-index: 9999;">
    <div class="text-center ren-mono">
        <h2 class="fw-800 mb-4">> SYNCHRONIZING_DATA...</h2>
        <div class="border border-1 border-dark p-1 mb-4 mx-auto" style="width: 250px; height: 20px;">
            <div id="loading-bar" class="bg-dark h-100" style="width: 0%;"></div>
        </div>
        <p class="small fw-bold text-uppercase blink opacity-50">Integrating_with_Core_Manifest</p>
    </div>
</div>

<script>
(() => {
    'use strict'
    const form = document.getElementById('log-form');
    const overlay = document.getElementById('loading-overlay');
    const bar = document.getElementById('loading-bar');
    const submitBtn = form.querySelector('button[type="submit"]');

    form.addEventListener('submit', event => {
        if (!form.checkValidity()) {
            event.preventDefault();
            event.stopPropagation();
            form.classList.add('was-validated');
        } else {
            form.classList.add('was-validated');
            submitBtn.disabled = true;
            submitBtn.innerText = "SYNCHRONIZING...";

            overlay.classList.remove('d-none');
            let width = 0;
            const interval = setInterval(() => {
                if (width >= 100) {
                    clearInterval(interval);
                } else {
                    width += 4; // Faster increment for better UX
                    bar.style.width = width + '%';
                }
            }, 25);
        }
    }, false);
})();
</script>