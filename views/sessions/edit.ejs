<% layout('layouts/boilerplate') %>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            
            <header class="mb-5 text-center ren-mono">
                <small class="opacity-40 text-uppercase" style="letter-spacing: 2px;">
                    > DATA_ID: <%= session._id.toString().slice(-6) %>
                </small>
                <h1 class="display-5 fw-800 mt-2 text-uppercase">REVISE_ENTRY</h1>
            </header>

            <div class="p-4 p-md-5 border border-dark border-opacity-10 bg-white shadow-sm">
                <form action="/sessions/<%= session._id %>?_method=PUT" method="POST">
                    
                    <div class="mb-4">
                        <label class="ren-mono small opacity-50 text-uppercase mb-2">Primary_Label</label>
                        <input type="text" name="session[title]" 
                               class="form-control bg-light border-0 rounded-0 p-3 ren-mono fw-bold shadow-none" 
                               value="<%= session.title %>" required>
                    </div>

                    <div class="mb-4">
                        <label class="ren-mono small opacity-50 text-uppercase mb-2">Duration_Mins</label>
                        <input type="number" name="session[duration]" 
                               class="form-control bg-light border-0 rounded-0 p-3 ren-mono fw-bold shadow-none" 
                               value="<%= session.duration %>" required>
                    </div>

                    <div class="mb-5">
                        <label class="ren-mono small opacity-50 text-uppercase mb-2">Log_Notes</label>
                        <textarea name="session[description]" 
                                  class="form-control bg-light border-0 rounded-0 p-3 ren-mono" 
                                  rows="3"><%= session.description %></textarea>
                    </div>

                    <div class="d-grid gap-3">
                        <button class="btn btn-dark py-3 ren-mono fw-bold text-uppercase rounded-0 shadow-sm">
                            COMMIT_CHANGES
                        </button>
                        
                        <a href="/sessions/<%= session._id %>" class="btn btn-outline-secondary py-2 ren-mono small text-uppercase rounded-0 border-opacity-25">
                            ABORT_REVISION
                        </a>
                    </div>
                </form> 

                <hr class="my-5 border-dark border-opacity-10">

                <form action="/sessions/<%= session._id %>?_method=DELETE" method="POST" 
                      onsubmit="return confirm('CONFIRM DATA PURGE: This will revert progress units.')">
                    <div class="text-center">
                        <button class="btn btn-link text-danger ren-mono small text-uppercase rounded-0 border-0 opacity-50 text-decoration-none p-0">
                            [ ! ]_DELETE_PERMANENTLY
                        </button>
                    </div>
                </form>
            </div>

            <div class="text-center mt-4">
                <p class="ren-mono small opacity-25">> AWAITING_INPUT_VALIDATION</p>
            </div>
        </div>
    </div>
</div>