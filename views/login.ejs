<%- layout('layouts/boilerplate') %>

<div class="row justify-content-center mt-5 pt-lg-5">
  <div class="col-md-5 col-lg-4">
    <div class="card ren-hud-border bg-black text-white p-4 shadow-lg">
      
      <div class="mb-4 border-bottom border-secondary pb-2">
        <h4 class="ren-mono ren-glow-text fw-800 mb-1" style="font-size: 1.1rem;">
          SYSTEM.AUTH_LOGIN
        </h4>
        <p class="ren-meta opacity-50 mb-0">STATUS: IDENTITY_VERIFICATION_REQUIRED</p>
      </div>

      <% if (error && error.length > 0) { %>
        <div class="ren-terminal-alert">[ERR]: <%= error %></div>
      <% } %>
      <% if (error_msg && error_msg.length > 0) { %>
        <div class="ren-terminal-alert">[ERR]: <%= error_msg %></div>
      <% } %>
      <% if (success_msg && success_msg.length > 0) { %>
        <div class="alert alert-dark border-info text-info small py-2 rounded-0 ren-mono" style="font-size: 0.7rem;">
          [SUCCESS]: <%= success_msg %>
        </div>
      <% } %>

      <form action="/auth/login" method="POST">
        <div class="mb-3">
          <label class="ren-label">Operator_ID (Email)</label>
          <input type="email" name="username"
            class="form-control ren-input"
            placeholder="NAME@DOMAIN.COM" required />
        </div>
        
        <div class="mb-4">
          <label class="ren-label">Access_Key</label>
          <input type="password" name="password"
            class="form-control ren-input"
            placeholder="••••••••" required />
        </div>

        <div class="d-grid mb-3">
          <button type="submit" class="btn ren-btn-execute">
            Execute_Auth.exe
          </button>
        </div>
      </form>

      <div class="position-relative my-4">
        <hr class="border-secondary opacity-25">
        <span class="position-absolute top-50 start-50 translate-middle bg-black px-3 ren-meta opacity-50">
          OR_OAUTH
        </span>
      </div>

      <div class="d-grid">
        <a href="/auth/google" class="btn btn-outline-secondary rounded-0 ren-mono small py-2 d-flex align-items-center justify-content-center" style="font-size: 0.75rem; letter-spacing: 1px;">
          <img src="https://www.svgrepo.com/show/475656/google-color.svg" width="16" class="me-2 opacity-75" />
          LINK_GOOGLE_ACCOUNT
        </a>
      </div>

      <div class="text-center mt-4 pt-3 border-top border-secondary border-opacity-25">
        <p class="ren-meta mb-0">
          NO_IDENTITY? <a href="/auth/register" class="text-info text-decoration-none fw-bold">CREATE_NEW_OPERATOR</a>
        </p>
      </div>

    </div>
  </div>
</div>