<% layout('layouts/boilerplate') %>

<div class="row justify-content-center mt-lg-5 pt-lg-5">
    <div class="col-md-5">
        
        <% 
            // Safety check: ensure slot exists without crashing
            const activeSlot = (typeof slot !== 'undefined' && slot) ? slot : 'engineer'; 
            
            const identityMap = {
                engineer: { label: "ENGINEER", prompt: "Define your Build", placeholder: "e.g., AI Research Lab" },
                athlete: { label: "ATHLETE", prompt: "Define your Standard", placeholder: "e.g., Performance & Stamina" },
                thinker: { label: "THINKER", prompt: "Define your Synthesis", placeholder: "e.g., Technical Writing" }
            };
            const identity = identityMap[activeSlot] || identityMap.engineer;
        %>

        <div class="text-dark">
            <header class="mb-5">
                <small class="text-uppercase opacity-50 d-block mb-2 ren-mono" style="letter-spacing: 2px;">
                    > INITIALIZING_<%= identity.label %>_PROTOCOL
                </small>
                <h2 class="display-6 fw-500 ren-mono" style="letter-spacing: -1px; color: #000;">
                    <%= identity.prompt %>
                </h2>
            </header>

            <form action="/goals" method="POST" novalidate>
                
                <input type="hidden" name="goal[slot]" value="<%= activeSlot %>">

                <div class="mb-5">
                    <label class="text-uppercase opacity-50 small d-block mb-3 ren-mono">Objective_Name</label>
                    <input type="text" name="goal[title]" 
                           class="form-control bg-transparent text-dark border-0 border-bottom border-dark px-0 py-2 rounded-0 shadow-none" 
                           style="font-size: 1.2rem;"
                           placeholder="<%= identity.placeholder %>" required autofocus>
                </div>

                <div class="mb-5">
                    <label class="text-uppercase opacity-50 small d-block mb-3 ren-mono">Mission_Parameters</label>
                    <input type="text" name="goal[description]" 
                           class="form-control bg-transparent text-dark border-0 border-bottom border-dark px-0 py-2 rounded-0 shadow-none" 
                           style="font-size: 0.9rem;"
                           placeholder="Briefly describe the scope of this goal...">
                </div>

                <div class="mb-5">
                    <label class="text-uppercase opacity-50 small d-block mb-3 ren-mono">Monthly_Time_Target (Min)</label>
                    <input type="number" name="goal[targetMinutes]" 
                           class="form-control bg-transparent text-dark border-0 border-bottom border-dark px-0 py-2 rounded-0 shadow-none" 
                           style="font-size: 1.2rem;"
                           value="1200" required>
                    <div class="opacity-50 small mt-2 italic">
                        Guideline: 1200m (~40m/day) | 2400m (~80m/day)
                    </div>
                </div>

                <div class="d-flex align-items-center gap-4 pt-4">
                    <button type="submit" class="btn btn-solid-dark px-5 py-3 text-uppercase fw-800 rounded-0">
                        COMMIT_GOAL
                    </button>
                    
                    <a href="/dashboard" class="text-dark opacity-50 text-decoration-none small text-uppercase fw-bold ren-mono">
                        [ ABORT ]
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>