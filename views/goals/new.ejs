<% layout('layouts/boilerplate') %>

<div class="row justify-content-center mt-lg-5 pt-lg-5">
    <div class="col-md-5">
        
        <% 
            // Fallback to 'engineer' if slot is missing from the query string
            const currentSlot = slot || 'engineer'; 
            
            const identityMap = {
                engineer: { label: "ENGINEER_SLOT", prompt: "WHAT_IS_YOUR_BUILD?", placeholder: "e.g., Build an AI bot" },
                athlete: { label: "ATHLETE_SLOT", prompt: "WHAT_IS_THE_STANDARD?", placeholder: "e.g., 45min Morning HIIT Workout" },
                thinker: { label: "THINKER_SLOT", prompt: "WHAT_WILL_YOU_SYNTHESIZE?", placeholder: "e.g., Technical Essays" }
            };
            const activeIdentity = identityMap[currentSlot];
        %>

        <div class="text-dark">
            <header class="mb-5">
                <small class="text-uppercase opacity-50 d-block mb-2" style="font-family: 'Geist Mono', monospace; letter-spacing: 2px;">
                    > INITIALIZING_<%= activeIdentity.label %>
                </small>
                <h2 class="display-6 fw-500" style="font-family: 'Geist Mono', monospace; letter-spacing: -1px; color: #000;">
                    <%= activeIdentity.prompt %>
                </h2>
            </header>

            <form action="/goals" method="POST" novalidate>
                
                <% if (slot) { %>
                    <input type="hidden" name="goal[slot]" value="<%= slot %>">
                <% } else { %>
                    <div class="mb-5">
                        <label class="text-uppercase opacity-50 small d-block mb-3" style="font-family: 'Geist Mono', monospace;">Select_Subsystem</label>
                        <select name="goal[slot]" class="form-select bg-transparent border-0 border-bottom border-dark rounded-0 shadow-none px-0">
                            <option value="engineer">ENGINEER (THE_BIG_ROCK)</option>
                            <option value="athlete">ATHLETE (HABIT_I)</option>
                            <option value="thinker">THINKER (HABIT_II)</option>
                        </select>
                    </div>
                <% } %>

                <div class="mb-5">
                    <label class="text-uppercase opacity-50 small d-block mb-3" style="font-family: 'Geist Mono', monospace; color: #000;">Project_Name</label>
                    <input type="text" name="goal[title]" 
                           class="form-control bg-transparent text-dark border-0 border-bottom border-dark px-0 py-2 rounded-0 shadow-none" 
                           style="font-size: 1.2rem;"
                           placeholder="<%= activeIdentity.placeholder %>" required autofocus>
                </div>

                <div class="mb-5">
                    <label class="text-uppercase opacity-50 small d-block mb-3" style="font-family: 'Geist Mono', monospace; color: #000;">Monthly_Target_Minutes</label>
                    <input type="number" name="goal[targetMinutes]" 
                           class="form-control bg-transparent text-dark border-0 border-bottom border-dark px-0 py-2 rounded-0 shadow-none" 
                           style="font-size: 1.2rem;"
                           value="1200" required>
                    <div class="opacity-50 small mt-2" style="font-family: 'IBM Plex Sans', sans-serif; font-style: italic;">
                        1200m (~40m/day) // 2400m (~80m/day)
                    </div>
                </div>

                <div class="d-flex align-items-center gap-4 pt-4">
                    <button type="submit" class="btn btn-solid-dark px-5 py-3 text-uppercase fw-800 rounded-0">
                        COMMIT_TO_IDENTITY
                    </button>
                    
                    <a href="/dashboard" class="text-dark opacity-50 text-decoration-none small text-uppercase fw-bold" style="font-family: 'Geist Mono', monospace;">
                        [ CANCEL ]
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>