<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ren | Skill Tracker</title>
    <link rel="icon" type="image/x-icon" href="/favicon.ico">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/geist@1.3.0/dist/fonts/geist-mono/style.css">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;600;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/app.css">
</head>
<body class="bg-white">

    <%- include('../partials/navbar') %>

    <main>
        <% if ((typeof success_msg !== 'undefined' && success_msg.length > 0) || (typeof error_msg !== 'undefined' && error_msg.length > 0 && !currentUser)) { %>
            <div class="border-bottom border-dark border-opacity-10 py-3">
                <div class="container">
                    <% if (typeof success_msg !== 'undefined' && success_msg.length > 0) { %>
                        <div class="ren-terminal-alert border-success text-success mb-2"><%= success_msg %></div>
                    <% } %>
                    <% if (typeof error_msg !== 'undefined' && error_msg.length > 0) { %>
                        <div class="ren-terminal-alert border-danger text-danger mb-2"><%= error_msg %></div>
                    <% } %>
                </div>
            </div>
        <% } %>
        <%- body %>
    </main>

    <div class="modal fade" id="loginModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content ren-hud-border border-0 rounded-0 shadow-lg bg-black p-4">
                <div class="modal-header border-0 pb-0">
                    <div>
                        <p class="ren-label mb-1 text-white opacity-50">> AUTH_PORTAL</p>
                        <h5 class="modal-title fw-800 text-white">WELCOME_BACK</h5>
                    </div>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <form action="/auth/login" method="POST">
                        <div class="mb-3">
                            <label class="ren-label text-white small opacity-50 d-block mb-2">EMAIL_ADDRESS</label>
                            <input type="email" name="email" class="form-control ren-input bg-transparent text-white border-secondary rounded-0 py-2" required />
                        </div>
                        <div class="mb-4">
                            <label class="ren-label text-white small opacity-50 d-block mb-2">ACCESS_KEY</label>
                            <input type="password" name="password" class="form-control ren-input bg-transparent text-white border-secondary rounded-0 py-2" required />
                        </div>
                        <button type="submit" class="btn btn-light w-100 rounded-0 fw-bold py-3 mb-3">INITIALIZE_SESSION</button>
                    </form>

                    <div class="d-flex align-items-center gap-2 my-3">
                        <div class="flex-grow-1" style="height:1px; background: rgba(255,255,255,0.1);"></div>
                        <span class="ren-meta opacity-50 small ren-mono" style="font-size: 0.7rem;">OR</span>
                        <div class="flex-grow-1" style="height:1px; background: rgba(255,255,255,0.1);"></div>
                    </div>

                    <a href="/auth/google" class="btn btn-outline-secondary w-100 fw-600 rounded-0 d-flex align-items-center justify-content-center gap-2 py-2" style="border-color: #444; color: #ccc; text-decoration: none;">
                        <img src="https://www.svgrepo.com/show/475656/google-color.svg" width="18" />
                        CONTINUE_WITH_GOOGLE
                    </a>

                    <p class="text-center mt-4 mb-0 small ren-mono">
                        <span class="opacity-50 text-white">NO_ACCOUNT?</span> 
                        <a href="#" class="text-white fw-bold text-decoration-none" data-bs-toggle="modal" data-bs-target="#registerModal" data-bs-dismiss="modal">REGISTER_→</a>
                    </p>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="registerModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content ren-hud-border border-0 rounded-0 shadow-lg bg-black p-4">
                <div class="modal-header border-0 pb-0">
                    <div>
                        <p class="ren-label mb-1 text-white opacity-50">> NEW_OPERATOR</p>
                        <h5 class="modal-title fw-800 text-white">IDENTITY_CREATION</h5>
                    </div>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <form action="/auth/register" method="POST">
                        <div class="mb-3">
                            <label class="ren-label text-white small opacity-50 d-block mb-2">OPERATOR_NAME</label>
                            <input type="text" name="username" class="form-control bg-transparent text-white border-secondary rounded-0 py-2" required />
                        </div>
                        <div class="mb-3">
                            <label class="ren-label text-white small opacity-50 d-block mb-2">EMAIL_ADDRESS</label>
                            <input type="email" name="email" class="form-control bg-transparent text-white border-secondary rounded-0 py-2" required />
                        </div>
                        <div class="mb-4">
                            <label class="ren-label text-white small opacity-50 d-block mb-2">CREATE_PASSWORD</label>
                            <input type="password" name="password" class="form-control bg-transparent text-white border-secondary rounded-0 py-2" required />
                        </div>
                        <button type="submit" class="btn btn-light w-100 rounded-0 fw-bold py-3 mb-3">CREATE_ACCOUNT</button>
                    </form>

                    <div class="d-flex align-items-center gap-2 my-3">
                        <div class="flex-grow-1" style="height:1px; background: rgba(255,255,255,0.1);"></div>
                        <span class="ren-meta opacity-50 small ren-mono" style="font-size: 0.7rem;">OR</span>
                        <div class="flex-grow-1" style="height:1px; background: rgba(255,255,255,0.1);"></div>
                    </div>

                    <a href="/auth/google" class="btn btn-outline-secondary w-100 fw-600 rounded-0 d-flex align-items-center justify-content-center gap-2 py-2" style="border-color: #444; color: #ccc; text-decoration: none;">
                        <img src="https://www.svgrepo.com/show/475656/google-color.svg" width="18" />
                        SIGN_UP_WITH_GOOGLE
                    </a>

                    <p class="text-center mt-4 mb-0 small ren-mono">
                        <span class="opacity-50 text-white">ALREADY_REGISTERED?</span> 
                        <a href="#" class="text-white fw-bold text-decoration-none" data-bs-toggle="modal" data-bs-target="#loginModal" data-bs-dismiss="modal">LOGIN_→</a>
                    </p>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Re-opens login modal if server returns an error during auth
            <% if ((typeof error !== 'undefined' && error.length > 0) || (typeof error_msg !== 'undefined' && error_msg.length > 0)) { %>
                const loginEl = document.getElementById('loginModal');
                const loginModal = new bootstrap.Modal(loginEl);
                loginModal.show();
            <% } %>
        });
    </script>
</body>
</html>