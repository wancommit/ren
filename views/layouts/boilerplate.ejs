<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ren | Skill Tracker</title>
    <link rel="icon" type="image/x-icon" href="/favicon.ico">

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/geist@1.3.0/dist/fonts/geist-mono/style.css">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;600;800&display=swap" rel="stylesheet">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <link rel="stylesheet" href="/css/app.css">
</head>

<body>

    <%- include('../partials/navbar') %>

    <main>
        <%- body %>
    </main>

    <div class="modal fade" id="loginModal" tabindex="-1" aria-labelledby="loginModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content ren-hud-border border-0 rounded-0 shadow-lg bg-black">
                <div class="modal-header border-0 pb-0">
                    <div>
                        <p class="ren-label mb-1">> AUTH_PORTAL</p>
                        <h5 class="modal-title fw-800 text-white" id="loginModalLabel">WELCOME_BACK</h5>
                    </div>
                    <button type="button" class="btn-close btn-close-white opacity-50" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body pt-3">
                    <% if (typeof error !== 'undefined' && error && error.length > 0) { %>
                        <div class="ren-terminal-alert"><%= error %></div>
                    <% } %>
                    <% if (typeof error_msg !== 'undefined' && error_msg && error_msg.length > 0) { %>
                        <div class="ren-terminal-alert"><%= error_msg %></div>
                    <% } %>

                    <form action="/auth/login" method="POST">
                        <div class="mb-3">
                            <label class="ren-label">Email</label>
                            <input type="email" name="email" class="form-control ren-input" placeholder="user@domain.com" required />
                        </div>
                        <div class="mb-4">
                            <label class="ren-label">Password</label>
                            <input type="password" name="password" class="form-control ren-input" placeholder="••••••••" required />
                        </div>
                        <div class="d-grid mb-3">
                            <button type="submit" class="ren-btn-execute">INITIALIZE_SESSION</button>
                        </div>
                    </form>

                    <div class="d-flex align-items-center gap-2 my-3">
                        <div class="flex-grow-1" style="height:1px; background: rgba(255,255,255,0.1);"></div>
                        <span class="ren-meta">OR</span>
                        <div class="flex-grow-1" style="height:1px; background: rgba(255,255,255,0.1);"></div>
                    </div>

                    <div class="d-grid mb-3">
                        <a href="/auth/google" class="btn btn-outline-secondary fw-600 rounded-0 d-flex align-items-center justify-content-center gap-2" style="border-color: #444; color: #ccc;">
                            <img src="https://www.svgrepo.com/show/475656/google-color.svg" width="18" />
                            CONTINUE_WITH_GOOGLE
                        </a>
                    </div>

                    <p class="text-center ren-meta mt-3 mb-0">
                        NO_ACCOUNT?
                        <a href="#" class="text-white fw-600" data-bs-toggle="modal" data-bs-target="#registerModal" data-bs-dismiss="modal" style="text-decoration: none;">
                            REGISTER →
                        </a>
                    </p>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="registerModal" tabindex="-1" aria-labelledby="registerModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content ren-hud-border border-0 rounded-0 shadow-lg bg-black">
                <div class="modal-header border-0 pb-0">
                    <div>
                        <p class="ren-label mb-1">> SYSTEM_ENROLLMENT</p>
                        <h5 class="modal-title fw-800 text-white" id="registerModalLabel">CREATE_OPERATOR</h5>
                    </div>
                    <button type="button" class="btn-close btn-close-white opacity-50" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body pt-3">
                    <form action="/auth/register" method="POST">
                        <div class="mb-3">
                            <label class="ren-label">Username</label>
                            <input type="text" name="username" class="form-control ren-input" placeholder="OPERATOR_01" required />
                        </div>
                        <div class="mb-3">
                            <label class="ren-label">Email</label>
                            <input type="email" name="email" class="form-control ren-input" placeholder="user@domain.com" required />
                        </div>
                        <div class="mb-4">
                            <label class="ren-label">Password</label>
                            <input type="password" name="password" class="form-control ren-input" placeholder="••••••••" required />
                        </div>
                        <div class="d-grid mb-3">
                            <button type="submit" class="ren-btn-execute">INITIALIZE_ACCOUNT</button>
                        </div>
                    </form>

                    <p class="text-center ren-meta mt-3 mb-0">
                        HAVE_ACCOUNT?
                        <a href="#" class="text-white fw-600" data-bs-toggle="modal" data-bs-target="#loginModal" data-bs-dismiss="modal" style="text-decoration: none;">
                            LOGIN →
                        </a>
                    </p>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

</body>
</html>