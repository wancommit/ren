<% layout('layouts/boilerplate') %>

    <div class="container d-flex flex-column align-items-center justify-content-center min-vh-100 py-5">
        <div class="text-center" style="max-width: 600px;">
            <!-- Glitch Effect Container -->
            <div class="position-relative d-inline-block mb-4">
                <h1 class="display-1 fw-800 ren-mono text-dark mb-0"
                    style="letter-spacing: -5px; text-shadow: 2px 2px 0px rgba(255,0,0,0.5), -2px -2px 0px rgba(0,255,255,0.5);">
                    404
                </h1>
            </div>

            <h2 class="h4 ren-mono text-dark opacity-75 mb-4 text-uppercase">
                > SYSTEM_ERROR // SECTOR_NOT_FOUND
            </h2>

            <div
                class="ren-terminal-alert border-danger text-danger mb-5 text-start p-4 bg-light border border-1 border-opacity-25 border-danger">
                <p class="ren-mono fw-bold small mb-1">> RUNNING DIAGNOSTIC...</p>
                <p class="ren-mono fw-bold small mb-1">> TARGET COORDINATES INVALID.</p>
                <p class="ren-mono fw-bold small mb-0">> THE REQUESTED DATABANK HAS BEEN PURGED OR NEVER EXISTED.</p>
            </div>

            <a href="/dashboard"
                class="btn btn-outline-dark rounded-0 py-3 px-5 ren-mono fw-bold text-uppercase d-inline-flex align-items-center gap-2"
                style="border-width: 2px;">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                    stroke-linecap="round" stroke-linejoin="round">
                    <path d="M19 12H5M12 19l-7-7 7-7" />
                </svg>
                RETURN_TO_BASE
            </a>
        </div>
    </div>